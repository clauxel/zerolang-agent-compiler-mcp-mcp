{
  "name": "zerolangcompiler",
  "title": "ZeroLang Agent Compiler MCP",
  "description": "A paid remote MCP for ZeroLang, built to return verdicts, receipts, usage logs, and audit-ready JSON for agent and CI workflows.",
  "version": "1.0.0",
  "websiteUrl": "https://zerolangcompiler.clauxel.com/",
  "documentationUrl": "https://zerolangcompiler.clauxel.com/mcp/",
  "endpointUrl": "https://zerolangcompiler.clauxel.com/mcp",
  "transport": "streamable-http",
  "authentication": {
    "type": "bearer",
    "required": true,
    "header": "Authorization",
    "format": "Bearer <paid-token>"
  },
  "paidAccess": {
    "required": true,
    "checkoutUrl": "https://zerolangcompiler.clauxel.com/api/agent-checkout",
    "tokenStatusUrl": "https://zerolangcompiler.clauxel.com/api/mcp-token/status",
    "tokenClaimUrl": "https://zerolangcompiler.clauxel.com/api/mcp-token/claim",
    "defaultPlan": "team",
    "pricing": [
      {
        "id": "solo",
        "name": "Solo",
        "monthlyUsd": 29
      },
      {
        "id": "team",
        "name": "Team",
        "monthlyUsd": 89
      },
      {
        "id": "dev-platform",
        "name": "Dev Platform",
        "monthlyUsd": 229
      }
    ]
  },
  "tools": [
    {
      "name": "compile_zerolang_program",
      "description": "ZeroLang Agent Compiler MCP compile zerolang program",
      "inputSchema": {
        "type": "object",
        "properties": {
          "sample": {
            "type": "string",
            "description": "Workflow sample, schema, policy fixture, or agent output."
          },
          "context": {
            "type": "string",
            "description": "Optional review context."
          }
        },
        "required": [
          "sample"
        ]
      },
      "outputSchema": {
        "type": "object",
        "properties": {
          "verdict": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "receipt_id": {
            "type": "string"
          },
          "usage_units": {
            "type": "integer"
          },
          "next_action": {
            "type": "string"
          }
        }
      }
    },
